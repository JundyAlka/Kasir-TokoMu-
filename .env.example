# Postgres connection string. Local Docker default uses port 5439 (see README).
DATABASE_URL=postgres://postgres:postgres@localhost:5439/warungos

# Better Auth — generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Server-side AI gateway. x5LAB is OpenAI-compatible:
# AI_GATEWAY_BASE_URL=https://api.x5lab.dev/v1
# AI_GATEWAY_API_KEY=replace-with-server-side-key
# AI_GATEWAY_MODEL=gpt-4o
# AI_GATEWAY_VISION_MODEL=gpt-4o
