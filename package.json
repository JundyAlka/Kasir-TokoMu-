{
  "name": "warungos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "db:start": "node ./scripts/start-db.mjs",
    "db:reset": "node --env-file=.env ./scripts/reset-db.mjs",
    "db:generate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed": "node --env-file=.env --import tsx ./scripts/seed.ts",
    "db:studio": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio",
    "auth:generate": "better-auth generate --config src/lib/auth.ts",
    "auth:migrate": "better-auth migrate --config src/lib/auth.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@react-pdf/renderer": "^4.5.1",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "embedded-postgres": "^18.4.0-beta.17",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "msw": "^2.14.6",
    "pg-mem": "^3.0.14",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
